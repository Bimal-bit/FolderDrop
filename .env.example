# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.

# Upstash Redis (get from console.upstash.com)
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...

# Supabase Storage (get from supabase.com/dashboard -> Project Settings -> API)
SUPABASE_URL=https://xyzxyzxyz.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_BUCKET=folderdrop-files

# Security: generate with `openssl rand -hex 32`
INTERNAL_CLEANUP_TOKEN=your-random-secret-here
